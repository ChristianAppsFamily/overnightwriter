# OvernightWriter — Environment Variables
# Copy this to .env.local and fill in your values

# Supabase (from your Supabase project settings > API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role (for serverless functions only — never expose to client)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe
STRIPE_SECRET_KEY=sk_test_XXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXX

# Model key encryption (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
MODEL_KEY_ENCRYPTION_KEY=your-64-char-hex-key-here

# AdSense (add to index.html meta tag + AdBanner component)
# VITE_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXXX
# VITE_ADSENSE_AD_UNIT_ID=XXXXXXXXXX
